# App
APP_NAME=Drama Agent Studio
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
WEB_PORT=3000

# Database
# Default: SQLite (zero-setup). Optional: PostgreSQL for production.
DATABASE_URL=sqlite+aiosqlite:///./data/app.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/drama_agent

# Storage
STORAGE_DRIVER=local
STORAGE_PATH=./storage

# LLM Provider
LITELLM_ENABLED=true
DEFAULT_TEXT_MODEL=deepseek/deepseek-chat
DEFAULT_FAST_MODEL=gpt-4o-mini
DEFAULT_SCRIPT_MODEL=deepseek/deepseek-chat
DEFAULT_REVIEW_MODEL=gpt-4o-mini

# API Keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
GEMINI_API_KEY=

# Image Models (optional)
IMAGE_PROVIDER=none
FAL_KEY=
REPLICATE_API_TOKEN=
COMFYUI_BASE_URL=

# Video Models (optional)
VIDEO_PROVIDER=none
KLING_API_KEY=
RUNWAY_API_KEY=
LUMA_API_KEY=

# MCP
MCP_ENABLED=true

# Security
SECRET_KEY=change-me
CORS_ORIGINS=http://localhost:3000
