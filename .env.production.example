# Generate AUTH_PASSWORD_HASH with:
# docker run --rm caddy:2-alpine caddy hash-password --plaintext 'replace-this'
AUTH_USER=admin
AUTH_PASSWORD_HASH=
APP_PUBLIC_PORT=3100
SECRET_KEY=

APP_ENV=production
PROJECT_ROOT=/workspace
DATABASE_URL=sqlite+aiosqlite:///./data/app.db
STORAGE_PATH=/workspace/storage
STORAGE_DIR=/workspace/storage
CORS_ORIGINS=
DRAMA_NODE_RUN_TIMEOUT_SECONDS=600
DRAMA_VIDEO_POLL_TIMEOUT_SECONDS=1200

# Keep secrets here. config/runtime.jsonc should refer to them as ${ENV_VAR}.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
GEMINI_API_KEY=
MEDIA_API_KEY=
