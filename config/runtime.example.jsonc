// Copy this file to config/runtime.jsonc when you want to manage providers by file.
// Keep real secrets in .env.local, .env.production, or shell environment variables.
// The API also auto-generates config/runtime.jsonc on first start from *_API_KEY env vars.
{
  "$schema_version": 1,
  "llm_providers": [
    {
      "name": "deepseek-default",
      "provider": "deepseek",
      "model_name": "deepseek-chat",
      "base_url": null,
      "api_key": "${DEEPSEEK_API_KEY}",
      "context_window_tokens": null,
      "max_input_tokens": null,
      "max_output_tokens": null,
      "supports_prompt_cache": null,
      "supports_vision": null,
      "tokenizer": null,
      "tier": "balanced",
      "enabled": true,
      "notes": "",
      "params": {}
    }
  ],
  "media_providers": [
    // Every base_url is a versioned/namespaced API Base URL, not a bare host
    // or a complete endpoint. Protocol request paths only contain resources.
    // 每个 base_url 都是带版本或命名空间的 API Base URL，不是裸域名或完整接口；
    // 协议中的 request path 只保存资源路径。
    // Image HTTP v1 keeps runtime connection data here and reads protocol
    // details from config/image_provider_protocols/catalog.json by id.
    // image_http_v1 只在这里保存运行时连接信息，协议细节按 id 从
    // config/image_provider_protocols/catalog.json 读取。
    {
      "kind": "image",
      "name": "image-openai-compatible-example",
      "base_url": "https://api.openai.com/v1",
      "api_key": "${IMAGE_API_KEY}",
      "model_name": "gpt-image-1",
      "api_format": "image_http_v1",
      "is_active": false,
      "enabled": false,
      "notes": "Example only. Copy and enable after filling a real API key.",
      "params": {
        "image_protocol_id": "openai_images_generations",
        "image_transport": "data_url"
      }
    },
    // Video HTTP v1 keeps runtime connection data here and reads protocol
    // details from config/video_provider_protocols/catalog.json by id.
    // video_http_v1 只在这里保存运行时连接信息，协议细节按 id 从
    // config/video_provider_protocols/catalog.json 读取。
    {
      "kind": "video",
      "name": "seedance-example",
      "base_url": "https://ark.cn-beijing.volces.com/api/v3",
      "api_key": "${VIDEO_API_KEY}",
      "model_name": "doubao-seedance-2-0-260128",
      "api_format": "video_http_v1",
      "is_active": false,
      "enabled": false,
      "notes": "Example only. Copy and enable after filling a real API key.",
      "params": {
        "video_protocol_id": "seedance_2_0",
        "image_transport": "data_url"
      }
    },
    // Audio HTTP v1 keeps runtime connection data here and reads protocol
    // details from config/audio_provider_protocols/catalog.json by id.
    // audio_http_v1 只在这里保存运行时连接信息，协议细节按 id 从
    // config/audio_provider_protocols/catalog.json 读取。
    {
      "kind": "audio",
      "name": "tts-example",
      "base_url": "https://api.openai.com/v1",
      "api_key": "${AUDIO_API_KEY}",
      "model_name": "tts-1",
      "api_format": "audio_http_v1",
      "is_active": false,
      "enabled": false,
      "notes": "Example only. Copy and enable after filling a real API key.",
      "params": {
        "audio_protocol_id": "openai_audio_speech"
      }
    }
  ],
  "model_tier_defaults": {
    "strong": null,
    "balanced": "deepseek-default",
    "small": null
  },
  "model_assignments": {},
  "app_settings": {
    "agent.max_iterations": 200,
    "agent.auto_archive": true,
    "agent.vision_context_max_images": 8,
    "agent.vision_context_max_dimension": 1536,
    "feature_flags": {},
    "kill_switches": {}
  }
}
