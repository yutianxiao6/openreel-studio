    "grok_1_5_multipart": {
      "version": "openreel.video_provider.v1",
      "id": "grok_1_5_multipart",
      "display_name": "Grok 1.5 Multipart",
      "strip_base_suffixes": ["/videos", "/v1"],
      "image_transport": "multipart_file",
      "supported_ratios": ["16:9", "9:16"],
      "supported_resolutions": ["480p", "720p"],
