        "succeeded": ["done", "completed", "succeeded"],
        "failed": ["failed", "expired", "cancelled", "canceled"],
        "running": ["running", "processing", "in_progress", "queued", "pending"],
        "interval_seconds": 10,
        "timeout_seconds": 1200
      },
      "result": {
        "video_url_paths": [
          "video.url",
          "response.video_url",
          "output.video_url",
          "output.url",
          "output",
          "video_url",
          "url",
          "data.video.url",
          "data.output",
          "data.video_url",
          "data.url"
        ]
      }
    },
