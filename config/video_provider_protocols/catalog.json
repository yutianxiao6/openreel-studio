{
  "version": "openreel.video_provider_catalog.v1",
  "protocols": {
    "seedance_2_0": {
      "version": "openreel.video_provider.v1",
      "id": "seedance_2_0",
      "display_name": "Seedance 2.0",
      "default_base_url": "https://ark.cn-beijing.volces.com/api/v3",
      "image_transport": "data_url",
      "supported_ratios": ["16:9", "4:3", "1:1", "3:4", "9:16", "21:9", "adaptive"],
      "duration": {
        "min": 4,
        "max": 15,
        "allowed_values": [-1]
      },
      "forbidden_fields": ["seed", "frames", "camera_fixed", "draft", "service_tier"],
      "model_profiles": [
        {
          "match": "doubao-seedance-2-0-260128",
          "label": "Standard",
          "supported_resolutions": ["480p", "720p", "1080p", "4k"],
          "default_resolution": "720p"
        },
        {
          "match": "doubao-seedance-2-0-fast-260128",
          "label": "Fast",
          "supported_resolutions": ["480p", "720p"],
          "default_resolution": "720p"
        },
        {
          "match": "doubao-seedance-2-0-mini-260615",
          "label": "Mini",
          "supported_resolutions": ["480p", "720p"],
          "default_resolution": "720p"
        }
      ],
      "modes": {
        "text_to_video": {
          "label": "Text to video",
          "prompt_required": true,
          "max_images": 0,
          "max_videos": 0,
          "max_audios": 0
        },
        "first_frame": {
          "label": "First frame to video",
          "prompt_required": false,
          "required_roles": ["first_frame"],
          "allowed_roles": ["first_frame"],
          "min_images": 1,
          "max_images": 1,
          "max_videos": 0,
          "max_audios": 0
        },
        "first_last_frame": {
          "label": "First and last frame to video",
          "prompt_required": false,
          "required_roles": ["first_frame", "last_frame"],
          "allowed_roles": ["first_frame", "last_frame"],
          "min_images": 2,
          "max_images": 2,
          "max_videos": 0,
          "max_audios": 0
        },
        "multimodal_reference": {
          "label": "Multimodal reference to video",
          "prompt_required": false,
          "allowed_roles": ["reference_image", "reference_video", "reference_audio"],
          "min_total_media": 1,
          "max_images": 9,
          "max_videos": 3,
          "max_audios": 3,
          "audio_requires_visual": true
        }
      },
      "content": {
        "text": {
          "type": "text",
          "type_key": "type",
          "text_key": "text"
        },
        "media_types": {
          "image": {
            "type": "image_url",
            "object_key": "image_url",
            "url_key": "url",
            "role_key": "role"
          },
          "video": {
            "type": "video_url",
            "object_key": "video_url",
            "url_key": "url",
            "role_key": "role"
          },
          "audio": {
            "type": "audio_url",
            "object_key": "audio_url",
            "url_key": "url",
            "role_key": "role"
          }
        }
      },
      "request": {
        "method": "POST",
        "path": "/contents/generations/tasks",
        "auth": "bearer",
        "task_id_paths": ["id"],
        "body": {
          "model": "$model",
          "content": "$content",
          "duration": "$duration_seconds",
          "ratio": "$aspect_ratio",
          "resolution": "$resolution",
          "generate_audio": "$generate_audio",
          "watermark": "$watermark",
          "return_last_frame": "$return_last_frame",
          "priority": "$priority",
          "execution_expires_after": "$execution_expires_after",
          "safety_identifier": "$safety_identifier",
          "tools": "$tools"
        }
      },
      "poll": {
        "method": "GET",
        "path": "/contents/generations/tasks/{task_id}",
        "status_path": "status",
        "succeeded": ["succeeded"],
        "failed": ["failed", "cancelled", "canceled", "expired"],
        "running": ["queued", "running", "processing"],
        "interval_seconds": 10,
        "timeout_seconds": 1200
      },
      "result": {
        "video_url_paths": ["content.video_url", "video_url", "content.url", "url"],
        "last_frame_url_paths": ["content.last_frame_url", "last_frame_url"]
      }
    },
    "lingke_media_generate_json_task": {
      "version": "openreel.video_provider.v1",
      "id": "lingke_media_generate_json_task",
      "display_name": "Lingke media.generate JSON task",
      "image_transport": "public_url",
      "supported_ratios": ["2:3", "3:2", "1:1"],
      "supported_resolutions": ["720p", "1080p"],
      "default_resolution": "720p",
      "duration": {
        "min": 6,
        "max": 60
      },
      "model_profiles": [
        {
          "match": "grok-video-3",
          "supported_resolutions": ["720p", "1080p"],
          "default_resolution": "720p",
          "duration": {
            "min": 6,
            "max": 60,
            "step": 1
          }
        }
      ],
      "modes": {
        "text_to_video": {
          "prompt_required": true,
          "max_images": 0,
          "max_videos": 0,
          "max_audios": 0
        },
        "first_frame": {
          "prompt_required": true,
          "allowed_roles": ["first_frame"],
          "min_images": 1,
          "max_images": 1,
          "max_videos": 0,
          "max_audios": 0
        },
        "first_last_frame": {
          "prompt_required": true,
          "allowed_roles": ["first_frame", "last_frame"],
          "min_images": 2,
          "max_images": 2,
          "max_videos": 0,
          "max_audios": 0
        },
        "multimodal_reference": {
          "prompt_required": true,
          "allowed_roles": ["reference_image", "first_frame", "last_frame"],
          "min_images": 1,
          "max_images": 12,
          "max_videos": 0,
          "max_audios": 0
        }
      },
      "content": {
        "media_types": {
          "image": {
            "type": "image_url",
            "object_key": "image_url",
            "url_key": "url",
            "role_key": "role"
          }
        }
      },
      "request": {
        "method": "POST",
        "path": "/media/generate",
        "auth": "bearer",
        "task_id_paths": [
          "data.task_id",
          "data.taskId",
          "data.id",
          "task_id",
          "taskId",
          "id",
          "job_id",
          "data.job_id"
        ],
        "body": {
          "model": "$model",
          "params": {
            "prompt": "$prompt",
            "images": "$image_urls",
            "aspect_ratio": "$aspect_ratio",
            "duration": "$duration_seconds",
            "resolution": "$resolution"
          }
        }
      },
      "poll": {
        "method": "GET",
        "path": "/skills/task-status?task_id={task_id}",
        "status_path": "state",
        "progress_path": "progress",
        "succeeded": ["success", "succeeded", "completed", "complete", "done"],
        "failed": ["failure", "failed", "error", "expired", "cancelled", "canceled"],
        "running": ["not_start", "queued", "pending", "running", "processing", "in_progress", "submitted"],
        "interval_seconds": 8,
        "timeout_seconds": 900
      },
      "result": {
        "video_url_paths": [
          "result_url",
          "data.result_url",
          "data.resultUrl",
          "data.video_url",
          "data.url",
          "data.output",
          "data.result.video_url",
          "data.result.url",
          "video_url",
          "url"
        ]
      }
    },
    "t8_grok_video_3_json_task": {
      "version": "openreel.video_provider.v1",
      "id": "t8_grok_video_3_json_task",
      "display_name": "T8 Grok Video 3 JSON task",
      "strip_base_suffixes": ["/v2/videos/generations", "/v2/videos", "/v1/files", "/v1", "/v2"],
      "image_transport": "upload_url",
      "supported_ratios": ["2:3", "3:2", "16:9", "9:16", "1:1"],
      "supported_resolutions": ["480p", "720p", "1080p"],
      "default_resolution": "720p",
      "default_ratio": "16:9",
      "resolution_output": "upper",
      "duration": {
        "min": 6,
        "max": 30
      },
      "resolution_rules": [
        {
          "duration_gt": 15,
          "supported_resolutions": ["720p"],
          "message": "T8 Grok Video 3 16-30 秒视频只支持 720p"
        }
      ],
      "model_profiles": [
        {
          "match": "grok-video-3",
          "supported_resolutions": ["480p", "720p", "1080p"],
          "default_resolution": "720p",
          "duration": {
            "min": 6,
            "max": 30,
            "step": 1
          }
        }
      ],
      "modes": {
        "text_to_video": {
          "prompt_required": true,
          "max_images": 0,
          "max_videos": 0,
          "max_audios": 0
        },
        "first_frame": {
          "prompt_required": true,
          "allowed_roles": ["first_frame"],
          "min_images": 1,
          "max_images": 1,
          "max_videos": 0,
          "max_audios": 0
        },
        "first_last_frame": {
          "prompt_required": true,
          "allowed_roles": ["first_frame", "last_frame"],
          "min_images": 2,
          "max_images": 2,
          "max_videos": 0,
          "max_audios": 0
        },
        "multimodal_reference": {
          "prompt_required": true,
          "allowed_roles": ["reference_image", "first_frame", "last_frame"],
          "min_images": 1,
          "max_images": 7,
          "max_videos": 0,
          "max_audios": 0
        }
      },
      "upload": {
        "method": "POST",
        "path": "/v1/files",
        "auth": "bearer",
        "file_field": "file",
        "url_paths": ["url", "data.url"]
      },
      "request": {
        "method": "POST",
        "path": "/v2/videos/generations",
        "auth": "bearer",
        "task_id_paths": ["task_id", "id", "job_id"],
        "body": {
          "model": "$model",
          "prompt": "$prompt",
          "ratio": "$aspect_ratio",
          "duration": "$duration_seconds",
          "resolution": "$resolution",
          "images": "$image_urls",
          "seed": "$seed"
        }
      },
      "poll": {
        "method": "GET",
        "path": "/v2/videos/generations/{task_id}",
        "status_path": "status",
        "progress_path": "progress",
        "succeeded": ["success", "done", "completed", "succeeded"],
        "failed": ["failure", "failed", "error", "expired", "cancelled", "canceled"],
        "running": ["not_start", "queued", "pending", "running", "processing", "in_progress"],
        "interval_seconds": 10,
        "timeout_seconds": 1200
      },
      "result": {
        "video_url_paths": ["data.output", "output", "video_url", "url", "data.video_url", "data.url"]
      }
    },
    "xai_grok_imagine_video": {
      "version": "openreel.video_provider.v1",
      "id": "xai_grok_imagine_video",
      "display_name": "xAI Grok Imagine Video",
      "default_base_url": "https://api.x.ai",
      "strip_base_suffixes": ["/videos/generations", "/videos", "/v1"],
      "image_transport": "data_url",
      "supported_ratios": ["1:1", "16:9", "9:16", "4:3", "3:4", "3:2", "2:3"],
      "supported_resolutions": ["480p", "720p", "1080p"],
      "default_ratio": "16:9",
      "default_resolution": "480p",
      "duration": {
        "min": 1,
        "max": 15
      },
      "model_profiles": [
        {
          "match": "grok-imagine-video",
          "supported_resolutions": ["480p", "720p", "1080p"],
          "default_resolution": "480p"
        }
      ],
      "modes": {
        "text_to_video": {
          "label": "文生视频",
          "prompt_required": true,
          "max_images": 0,
          "max_videos": 0,
          "max_audios": 0
        },
        "first_frame": {
          "label": "图生视频",
          "prompt_required": true,
          "allowed_roles": ["first_frame"],
          "min_images": 1,
          "max_images": 1,
          "max_videos": 0,
          "max_audios": 0
        },
        "multimodal_reference": {
          "label": "参考图生视频",
          "prompt_required": true,
          "allowed_roles": ["reference_image"],
          "min_images": 1,
          "max_images": 7,
          "max_videos": 0,
          "max_audios": 0,
          "duration": {
            "min": 1,
            "max": 10
          }
        }
      },
      "request": {
        "method": "POST",
        "path": "/v1/videos/generations",
        "auth": "bearer",
        "task_id_paths": ["request_id", "id", "task_id", "job_id"],
        "body": {
          "model": "$model",
          "prompt": "$prompt",
          "image": {
            "url": "$first_frame_image_url"
          },
          "reference_images": "$reference_image_objects",
          "duration": "$duration_seconds",
          "aspect_ratio": "$aspect_ratio",
          "resolution": "$resolution",
          "seed": "$seed"
        }
      },
      "poll": {
        "method": "GET",
        "path": "/v1/videos/{task_id}",
