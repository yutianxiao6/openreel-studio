{
  "schema": "openreel.workflow.v2",
  "id": "general_short_drama_workflow",
  "title": "通用视频制作工作流",
  "description": "从故事需求生成剧本、制作规划、人物与场景参考图、分镜图和最终视频。画布只展示可交付的文本与媒体节点。",
  "tags": ["video", "short_drama", "storyboard", "character_consistency"],
  "inputs": {
    "plot": {
      "type": "long_text",
      "label": "故事主题或剧情",
      "description": "可以是主题、简要情节或完整剧本。",
      "required": true
    },
    "style": {
      "type": "text",
      "label": "视觉风格",
      "description": "时代、摄影、材质、色彩和整体情绪。",
      "default": "电影感写实风格"
    },
    "video_type": {
      "type": "enum",
      "label": "视频类型",
      "default": "short_drama",
      "options": [
        {"value": "short_drama", "label": "短剧"},
        {"value": "short_film", "label": "电影短片"},
        {"value": "trailer", "label": "预告片"}
      ]
    },
    "episode_count": {
      "type": "integer",
      "label": "集数",
      "default": 1,
      "min": 1,
      "max": 100
    },
    "duration_seconds": {
      "type": "integer",
      "label": "单集总时长（秒）",
      "required": true,
      "default": 15,
      "min": 1,
      "max": 3600
    },
    "segment_seconds": {
      "type": "integer",
      "label": "每段时长（秒）",
      "default": 15,
      "min": 1,
      "max": 60
    },
    "aspect_ratio": {
      "type": "enum",
      "label": "画面比例",
      "default": "16:9",
      "options": [
        {"value": "16:9", "label": "横屏 16:9"},
        {"value": "9:16", "label": "竖屏 9:16"},
        {"value": "1:1", "label": "方形 1:1"}
      ]
    },
    "resolution": {
      "type": "enum",
      "label": "图片分辨率",
      "default": "2560x1440",
      "options": [
        {"value": "2560x1440", "label": "2K 横屏"},
        {"value": "1440x2560", "label": "2K 竖屏"},
        {"value": "2048x2048", "label": "2K 方形"}
      ]
    }
  },
  "steps": [
    {
      "id": "episode_plan",
      "title": "分集规划",
      "kind": "object",
      "description": "多集项目的连续剧情规划；单集项目自动跳过。",
      "when": {"path": "inputs.episode_count", "op": "gt", "value": 1},
      "prompt": {
        "role": "你是专业影视编剧，负责把总体情节拆成连续而各自完整的短剧分集。",
        "task": "根据剧情 {{ inputs.plot }}、风格 {{ inputs.style }}、类型 {{ inputs.video_type }} 和集数 {{ inputs.episode_count }} 规划每一集。",
        "output": "输出 episodes 数组；每项包含 index、title、plot、continuity_note。plot 写清主要事件、人物动机、冲突推进和结尾钩子。",
        "check": "集数准确；每集有独立起承转合；前后集因果衔接且悬念递进。"
      },
      "output": {
        "schema": {
          "fields": [
            {
              "id": "episodes",
              "type": "array",
              "label": "分集规划",
              "required": true,
              "fields": [
                {"id": "index", "type": "integer", "required": true},
                {"id": "title", "type": "string", "required": true},
                {"id": "plot", "type": "string", "required": true},
                {"id": "continuity_note", "type": "string", "required": true}
              ]
            }
          ]
        }
      }
    },
    {
      "id": "script",
      "title": "剧本",
      "kind": "text",
      "needs": ["episode_plan"],
      "prompt": {
        "role": "你是专业影视编剧和导演，负责写可直接用于视频生产的完整剧本。",
        "task": "根据剧情 {{ inputs.plot }}、视觉风格 {{ inputs.style }}、类型 {{ inputs.video_type }}、分集规划 {{ steps.episode_plan.output }}、单集时长 {{ inputs.duration_seconds }} 秒和每段时长 {{ inputs.segment_seconds }} 秒写剧本。",
        "output": "先写一句整体梗概，再按【第N段｜起止秒｜标题】拆段。每段包含场景环境、出场人物、动作、对白或旁白、情绪氛围和结尾画面。只写剧本正文。",
        "check": "段数按总时长除以每段时长向上取整；每段不超时；人物动机、冲突和画面连续。"
      },
      "output": {"canvas": true},
      "fields": {"purpose": "script", "stage": "script"}
    },
    {
      "id": "production_plan",
      "title": "制作规划",
      "kind": "object",
      "needs": ["script"],
      "prompt": {
        "role": "你是影视美术统筹和制片规划师，负责把剧本整理成稳定、可复用的生产数据。",
        "task": "阅读剧本 {{ steps.script.output }}，结合风格 {{ inputs.style }}、单集时长 {{ inputs.duration_seconds }} 秒和每段时长 {{ inputs.segment_seconds }} 秒，整理统一风格、主要人物与逐段制作计划。",
        "output": "输出 style_template、main_characters 和 segments。主要人物包含 character_id、name、identity、appearance、wardrobe、consistency_rules。每段包含 segment_id、index、start_second、end_second、duration_seconds、title、script_excerpt、appearing_character_ids、scene_brief。",
        "check": "人物 ID 稳定且唯一；segments 完整覆盖剧本时长且不重叠；段内人物 ID 必须来自 main_characters。"
      },
      "output": {
        "schema": {
          "fields": [
            {
              "id": "style_template",
              "type": "object",
              "required": true,
              "fields": [
                {"id": "visual_style", "type": "string", "required": true},
                {"id": "cinematography", "type": "string", "required": true},
                {"id": "color_palette", "type": "string", "required": true},
                {"id": "negative_constraints", "type": "string", "required": true}
              ]
            },
            {
              "id": "main_characters",
              "type": "array",
              "required": true,
              "fields": [
                {"id": "character_id", "type": "string", "required": true},
                {"id": "name", "type": "string", "required": true},
                {"id": "identity", "type": "string", "required": true},
                {"id": "appearance", "type": "string", "required": true},
                {"id": "wardrobe", "type": "string", "required": true},
                {"id": "consistency_rules", "type": "string", "required": true}
              ]
            },
            {
              "id": "segments",
              "type": "array",
              "required": true,
              "fields": [
                {"id": "segment_id", "type": "string", "required": true},
                {"id": "index", "type": "integer", "required": true},
                {"id": "start_second", "type": "integer", "required": true},
                {"id": "end_second", "type": "integer", "required": true},
                {"id": "duration_seconds", "type": "integer", "required": true},
                {"id": "title", "type": "string", "required": true},
                {"id": "script_excerpt", "type": "string", "required": true},
                {"id": "appearing_character_ids", "type": "array", "required": true},
                {"id": "scene_brief", "type": "string", "required": true}
              ]
            }
          ]
        }
      }
    },
    {
      "id": "character_images",
      "title": "主要人物参考图",
      "kind": "loop",
      "needs": ["production_plan"],
      "foreach": {
        "items": "steps.production_plan.output.main_characters[]",
        "as": "character",
        "key": "character_id"
      },
      "steps": [
        {
          "id": "character_image",
          "title": "人物参考图",
          "kind": "image",
          "prompt": {
            "role": "你是影视角色概念设计师，负责制作可跨镜头复用的高清人物定妆参考图。",
            "task": "为 {{ character.name }}（ID {{ character.character_id }}）制作人物定妆图。身份：{{ character.identity }}；外貌：{{ character.appearance }}；服装：{{ character.wardrobe }}；一致性规则：{{ character.consistency_rules }}；统一风格：{{ steps.production_plan.output.style_template }}。",
            "output": "写一段可直接用于图片模型的中文提示词，明确正面全身、自然站姿、清晰五官、服饰材质、统一光线和纯净背景。",
            "check": "不改变年龄、发型、五官、体型和核心服装；不加入其他人物、文字、水印或拼贴。"
          },
          "fields": {
            "purpose": "character_reference",
            "stage": "character_reference",
            "character_id": "{{ character.character_id }}",
            "aspect_ratio": "{{ inputs.aspect_ratio }}",
            "resolution": "{{ inputs.resolution }}",
            "quality": "high"
          }
        }
      ]
    },
    {
      "id": "segment_production",
      "title": "逐段制作",
      "kind": "loop",
      "needs": ["production_plan", "character_images"],
      "foreach": {
        "items": "steps.production_plan.output.segments[]",
        "as": "segment",
        "key": "segment_id"
      },
      "steps": [
        {
          "id": "segment_script",
          "title": "分段剧本",
          "kind": "text",
          "prompt": {
            "role": "你是现场执行导演，负责把完整剧本整理为当前视频段的准确执行稿。",
            "task": "根据完整剧本 {{ steps.script.output }} 和当前段 {{ segment }}，写当前段从 {{ segment.start_second }} 秒到 {{ segment.end_second }} 秒的执行稿。",
            "output": "只写当前段正文，包含时间、场景、人物、动作、对白或旁白、镜头节奏、声音和结尾画面。",
            "check": "内容只覆盖当前段；时长为 {{ segment.duration_seconds }} 秒；与相邻剧情和人物状态连续。"
          },
          "output": {"canvas": true},
          "fields": {"purpose": "segment_script", "stage": "segment_script"}
        },
        {
          "id": "scene_plan",
          "title": "场景与次要人物规划",
          "kind": "object",
          "needs": ["segment_script"],
          "prompt": {
            "role": "你是场景美术和选角统筹，负责当前段的场景一致性及次要人物管理。",
            "task": "阅读当前段剧本 {{ steps.segment_script.output }}、段信息 {{ segment }} 和统一风格 {{ steps.production_plan.output.style_template }}，整理场景与次要人物。",
            "output": "输出 scene 和 minor_characters。scene 包含 scene_id、location、time、weather、layout、lighting、props、continuity_rules；每个次要人物包含 character_id、name、appearance、wardrobe。",
            "check": "场景描述可直接出图；保留剧情指定的时间、天气、道具和空间关系；次要人物不与主要人物重复。"
          },
          "output": {
            "schema": {
              "fields": [
                {
                  "id": "scene",
                  "type": "object",
                  "required": true,
                  "fields": [
                    {"id": "scene_id", "type": "string", "required": true},
                    {"id": "location", "type": "string", "required": true},
                    {"id": "time", "type": "string", "required": true},
                    {"id": "weather", "type": "string"},
                    {"id": "layout", "type": "string", "required": true},
                    {"id": "lighting", "type": "string", "required": true},
                    {"id": "props", "type": "array"},
                    {"id": "continuity_rules", "type": "string", "required": true}
                  ]
                },
                {
                  "id": "minor_characters",
                  "type": "array",
                  "fields": [
                    {"id": "character_id", "type": "string", "required": true},
                    {"id": "name", "type": "string", "required": true},
                    {"id": "appearance", "type": "string", "required": true},
                    {"id": "wardrobe", "type": "string", "required": true}
                  ]
                }
              ]
            }
          }
        },
        {
          "id": "scene_reference",
          "title": "场景参考图",
          "kind": "image",
          "needs": ["scene_plan"],
          "prompt": {
            "role": "你是影视场景概念设计师，负责制作无人、高清、可复用的场景参考图。",
            "task": "根据当前场景 {{ steps.scene_plan.output.scene }}、当前段剧本 {{ steps.segment_script.output }} 和统一风格 {{ steps.production_plan.output.style_template }} 写场景图提示词。",
            "output": "写一段可直接用于图片模型的中文提示词，明确空间布局、时间天气、光线方向、核心道具、镜头视角、材质和景深。",
            "check": "场景中不出现人物；不改变关键空间关系和道具位置；不出现文字、水印或拼贴。"
          },
          "fields": {
            "purpose": "scene_reference",
            "stage": "scene_reference",
            "aspect_ratio": "{{ inputs.aspect_ratio }}",
            "resolution": "{{ inputs.resolution }}",
            "quality": "high"
          }
        },
        {
          "id": "frame_plan",
          "title": "分镜规划",
          "kind": "object",
          "needs": ["scene_reference"],
          "uses": [
            {"from": "scene_reference", "as": ["vision"]}
          ],
          "prompt": {
            "role": "你是分镜导演，负责根据真实参考图规划当前段的镜头序列。",
            "task": "看场景参考图，并结合当前段剧本 {{ steps.segment_script.output }}、场景数据 {{ steps.scene_plan.output }}、主要人物 {{ steps.production_plan.output.main_characters }} 和时长 {{ segment.duration_seconds }} 秒规划分镜。",
            "output": "输出 selected_character_ids 和 frames。每个 frame 包含 index、time_range、shot_size、camera、composition、characters、action、expression、dialogue_or_audio、continuity。",
            "check": "镜头总时长准确；动作可在时长内完成；轴线、视线、人物位置、服装和道具连续；selected_character_ids 只包含本段出场主要人物。"
          },
          "output": {
            "schema": {
              "fields": [
                {"id": "selected_character_ids", "type": "array", "required": true},
                {
                  "id": "frames",
                  "type": "array",
                  "required": true,
                  "fields": [
                    {"id": "index", "type": "integer", "required": true},
                    {"id": "time_range", "type": "string", "required": true},
                    {"id": "shot_size", "type": "string", "required": true},
                    {"id": "camera", "type": "string", "required": true},
                    {"id": "composition", "type": "string", "required": true},
                    {"id": "characters", "type": "array"},
                    {"id": "action", "type": "string", "required": true},
                    {"id": "expression", "type": "string"},
                    {"id": "dialogue_or_audio", "type": "string"},
                    {"id": "continuity", "type": "string", "required": true}
                  ]
                }
              ]
            }
          }
        },
        {
          "id": "storyboard",
          "title": "宫格分镜图",
          "kind": "image",
          "needs": ["frame_plan"],
          "uses": [
            {"from": "scene_reference", "as": ["vision", "reference"]},
            {
              "from": "character_image",
              "as": ["vision", "reference"],
              "select": {
                "values": "steps.frame_plan.output.selected_character_ids",
                "by": ["character_id"]
              }
            }
          ],
          "prompt": {
            "role": "你是影视分镜设计师，必须看场景图和人物定妆图来写最终宫格分镜图片提示词。",
            "task": "看全部指定参考图，根据分镜规划 {{ steps.frame_plan.output.frames }}、当前段剧本 {{ steps.segment_script.output }} 和场景数据 {{ steps.scene_plan.output }}，设计一张按时间顺序阅读的宫格分镜图。",
            "output": "写一段可直接用于图片模型的中文提示词，先规定统一角色、场景、光线和色彩，再逐格描述景别、机位、构图、人物位置、动作、表情和连续关系。",
            "check": "每格对应一个 frame；人物外貌服装与定妆图一致；场景布局与参考图一致；格子边界清晰；不出现字幕、水印或无关人物。"
          },
          "fields": {
            "purpose": "storyboard",
            "stage": "storyboard",
            "aspect_ratio": "{{ inputs.aspect_ratio }}",
            "resolution": "{{ inputs.resolution }}",
            "quality": "high"
          }
        },
        {
          "id": "final_video",
          "title": "最终视频",
          "kind": "video",
          "needs": ["storyboard"],
          "uses": [
            {"from": "storyboard", "as": ["vision", "reference"]},
            {"from": "scene_reference", "as": ["vision", "reference"]},
            {
              "from": "character_image",
              "as": ["vision", "reference"],
              "select": {
                "values": "steps.frame_plan.output.selected_character_ids",
                "by": ["character_id"]
              }
            }
          ],
          "prompt": {
            "role": "你是视频生成导演，必须看宫格分镜、场景图和人物定妆图来写可执行的视频提示词。",
            "task": "看全部指定参考图，根据当前段剧本 {{ steps.segment_script.output }}、分镜规划 {{ steps.frame_plan.output.frames }}、场景数据 {{ steps.scene_plan.output }} 和目标时长 {{ segment.duration_seconds }} 秒写最终视频提示词。",
            "output": "只写视频模型提示词。按时间顺序描述镜头、人物动作、表情、镜头运动、光线变化、环境动态、对白或声音和结束画面，并写明人物、服装、场景、道具一致性约束。",
            "check": "时长准确；动作和镜头数量可执行；不虚构参考图中不存在的角色特征；不输出 JSON、解释、标题或参数表。"
          },
          "fields": {
            "purpose": "final_video",
            "stage": "final_video",
            "production_path": "image_to_video",
            "duration_seconds": "{{ segment.duration_seconds }}",
            "aspect_ratio": "{{ inputs.aspect_ratio }}"
          }
        }
      ]
    }
  ],
  "ui": {
    "category": "视频制作",
    "accent": "violet"
  }
}
